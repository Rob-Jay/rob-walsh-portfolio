# Copy this file to .env and fill in your values.
# IMPORTANT: .env is gitignored. Never commit real keys.

# Anthropic API key for the "Ask Rob" AI chat widget.
# Get one at https://console.anthropic.com/
# Note: this key will be visible in the compiled JS bundle.
# That is acceptable for a personal portfolio — the only risk is
# someone running up a small bill on your behalf.
VITE_ANTHROPIC_API_KEY=

# Strava credentials (optional — see TrainingWidget.jsx for setup steps)
# VITE_STRAVA_CLIENT_ID=
# VITE_STRAVA_CLIENT_SECRET=
# VITE_STRAVA_REFRESH_TOKEN=
