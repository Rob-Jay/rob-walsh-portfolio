# Copy this file to .env and fill in your values.
# IMPORTANT: .env is gitignored. Never commit real keys.I

# Anthropic API key — used server-side only (Next.js API route).
# Never exposed to the browser. Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Strava credentials (optional — see TrainingWidget.jsx for setup steps)
# VITE_STRAVA_CLIENT_ID=
# VITE_STRAVA_CLIENT_SECRET=
# VITE_STRAVA_REFRESH_TOKEN=
